{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "partners.visionedu.site"
        }
      ],
      "destination": "/partners.html"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "visionedu.site"
        }
      ],
      "destination": "/platform.html"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "partners.visionedu.site"
        }
      ],
      "destination": "/partners.html"
    }
  ],
  "redirects": [
    {
      "source": "/partners",
      "has": [
        {
          "type": "host",
          "value": "visionedu.site"
        }
      ],
      "destination": "https://partners.visionedu.site",
      "permanent": true
    }
  ]
}
