{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "partners.visionedu.site"
        }
      ],
      "destination": "/partners"
    }
  ],
  "redirects": [
    {
      "source": "/partners",
      "has": [
        {
          "type": "host",
          "value": "visionedu.site"
        }
      ],
      "destination": "https://partners.visionedu.site",
      "permanent": true
    }
  ]
}
